#!/bin/bash
# maintenance вҖ” full Gentoo maintenance pass
# Runs: portage sync, world update, depclean, eclean-dist, failed units check, drive health, backup status
set -uo pipefail

# в”Җв”Җ Colors в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

ok()     { echo -e "${GREEN}вң”${NC}  $*"; }
fail()   { echo -e "${RED}вңҳ${NC}  $*"; ERRORS+=("$*"); }
info()   { echo -e "${CYAN}вҶ’${NC}  $*"; }
header() { echo -e "\n${BOLD}${CYAN}в•җв•җ $* в•җв•җ${NC}"; }

ERRORS=()

# в”Җв”Җ Root check в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if [[ $EUID -ne 0 ]]; then
    echo -e "${RED}Run with sudo.${NC}"
    exit 1
fi

echo -e "${BOLD}Gentoo Maintenance вҖ” $(date '+%Y-%m-%d %H:%M')${NC}"

# в”Җв”Җ 1. Sync portage tree в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
header "Sync portage tree"
if emerge --sync --quiet; then
    ok "Portage tree synced"
else
    fail "emerge --sync failed"
fi

# в”Җв”Җ 2. World update в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
header "World update"
info "Checking for updates..."
UPDATE_LIST=$(emerge -pvuDN @world 2>&1)
UPDATE_COUNT=$(echo "$UPDATE_LIST" | grep -c '^\[ebuild' || true)

if [[ $UPDATE_COUNT -eq 0 ]]; then
    ok "System already up to date"
else
    info "$UPDATE_COUNT package(s) to update:"
    echo "$UPDATE_LIST"
    echo ""
    emerge -uDN --keep-going --ask @world
    if [[ $? -eq 0 ]]; then
        ok "World update complete"
    else
        fail "World update finished with errors вҖ” check emerge output above"
    fi
fi

# в”Җв”Җ 3. Depclean в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
header "Depclean"
DEPCLEAN_OUT=$(emerge --depclean 2>&1)
REMOVED=$(echo "$DEPCLEAN_OUT" | grep 'Number removed:' | awk '{print $NF}')
if [[ "${REMOVED:-0}" -gt 0 ]]; then
    ok "Removed $REMOVED orphaned package(s)"
else
    ok "No orphaned packages"
fi

# в”Җв”Җ 4. Clean distfiles в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
header "Clean distfiles"
ECLEAN_OUT=$(eclean-dist --deep 2>&1)
FREED=$(echo "$ECLEAN_OUT" | grep 'Total space' | grep -oP '[\d.]+ \w+(?= from)')
if [[ -n "$FREED" ]]; then
    ok "Freed $FREED in distfiles"
else
    ok "Distfiles already clean"
fi

# в”Җв”Җ 5. Failed systemd units в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
header "Systemd units"
FAILED=$(systemctl --failed --no-legend --no-pager 2>/dev/null | grep -v '^$' || true)
if [[ -z "$FAILED" ]]; then
    ok "No failed units"
else
    fail "Failed units detected:"
    echo "$FAILED"
fi

# в”Җв”Җ 6. Drive health в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
header "Drive health"
SMART_RESULT=$(smartctl -H /dev/nvme0n1 2>/dev/null | grep 'SMART overall-health' || true)
if echo "$SMART_RESULT" | grep -q 'PASSED'; then
    ok "NVMe SMART: PASSED"
else
    fail "NVMe SMART check failed or inconclusive вҖ” run: sudo smartctl -a /dev/nvme0n1"
fi

# в”Җв”Җ 7. Restic backup status в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
header "Restic backups"
RESTIC_STATUS=$(systemctl show restic-backup.service --property=ActiveState,Result 2>/dev/null)
ACTIVE=$(echo "$RESTIC_STATUS" | grep 'ActiveState=' | cut -d= -f2)
RESULT=$(echo "$RESTIC_STATUS" | grep 'Result=' | cut -d= -f2)

if [[ "$RESULT" == "success" ]]; then
    LAST_RUN=$(journalctl -u restic-backup.service --no-pager -n 1 --output=short \
        | grep -oP '\w+ \d+ \d+:\d+:\d+')
    ok "Last backup: ${LAST_RUN:-unknown}"
elif [[ "$ACTIVE" == "activating" || "$ACTIVE" == "active" ]]; then
    info "Backup currently running"
else
    fail "Last backup did not succeed (Result=${RESULT}) вҖ” run: sudo systemctl start restic-backup.service"
fi

# в”Җв”Җ Summary в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
header "Summary"
if [[ ${#ERRORS[@]} -eq 0 ]]; then
    echo -e "${GREEN}${BOLD}All checks passed.${NC}"
else
    echo -e "${RED}${BOLD}${#ERRORS[@]} issue(s) need attention:${NC}"
    for e in "${ERRORS[@]}"; do
        echo -e "  ${RED}вҖў${NC} $e"
    done
    exit 1
fi
